{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestState",
  "description": "시험 실행 상태 머신",
  "oneOf": [
    {
      "description": "대기 중 (시험 없음)",
      "type": "string",
      "const": "idle"
    },
    {
      "description": "준비 중 (namespace 생성, 서버 기동 등)",
      "type": "string",
      "const": "preparing"
    },
    {
      "description": "Ramp-up 진행 중 (목표 부하까지 선형 증가)",
      "type": "string",
      "const": "ramping_up"
    },
    {
      "description": "시험 진행 중 (전속력)",
      "type": "string",
      "const": "running"
    },
    {
      "description": "Ramp-down 진행 중 (부하 감소 후 종료 대기)",
      "type": "string",
      "const": "ramping_down"
    },
    {
      "description": "중지 요청됨 (정리 중)",
      "type": "string",
      "const": "stopping"
    },
    {
      "description": "정상 완료",
      "type": "string",
      "const": "completed"
    },
    {
      "description": "오류로 종료",
      "type": "string",
      "const": "failed"
    }
  ]
}
